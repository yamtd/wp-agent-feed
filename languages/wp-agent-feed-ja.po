#. Plugin Name of the plugin
#: wp-agent-feed.php
msgid "WP Agent Feed"
msgstr "WP Agent Feed"

#: wp-agent-feed.php
msgid "General Settings"
msgstr "一般設定"

#: wp-agent-feed.php
msgid "Post Types"
msgstr "投稿タイプ"

#: wp-agent-feed.php
msgid "Content-Signal"
msgstr "Content-Signal"

#: wp-agent-feed.php
msgid "Configure how WP Agent Feed serves Markdown responses. Settings defined as constants in wp-config.php take priority over these values."
msgstr "WP Agent Feed の Markdown レスポンス配信方法を設定します。wp-config.php で定義された定数が優先されます。"

#: wp-agent-feed.php
msgid "Defined in wp-config.php. Remove the constant to manage this setting here."
msgstr "wp-config.php で定義されています。この設定をここで管理するには、定数を削除してください。"

#: wp-agent-feed.php
msgid "The Content-Signal header value sent with Markdown responses."
msgstr "Markdown レスポンスに付与される Content-Signal ヘッダーの値。"

#: wp-agent-feed.php
msgid "Cache Management"
msgstr "キャッシュ管理"

#. translators: %s is the cache directory path
#: wp-agent-feed.php
msgid "Cache directory: %s"
msgstr "キャッシュディレクトリ: %s"

#: wp-agent-feed.php
msgid "Regenerate All Cache"
msgstr "全キャッシュ再生成"

#: wp-agent-feed.php
msgid "Clear All Cache"
msgstr "全キャッシュ削除"

#: wp-agent-feed.php
msgid "Permission denied."
msgstr "権限がありません。"

#. translators: %d is the number of deleted cache files
#: wp-agent-feed.php
msgid "Deleted %d cache files."
msgstr "%d 件のキャッシュファイルを削除しました。"

#: wp-agent-feed.php
msgid "Starting..."
msgstr "開始中…"

#: wp-agent-feed.php
msgid "No posts to process."
msgstr "処理する投稿がありません。"

#: wp-agent-feed.php
msgid "Request failed."
msgstr "リクエストに失敗しました。"

#: wp-agent-feed.php
msgid "processed..."
msgstr "件処理済み…"

#: wp-agent-feed.php
msgid "cache files regenerated."
msgstr "件のキャッシュファイルを再生成しました。"

#: wp-agent-feed.php
msgid "Are you sure you want to clear all cache files?"
msgstr "すべてのキャッシュファイルを削除してもよろしいですか？"

#: wp-agent-feed.php
msgid "Clearing..."
msgstr "削除中…"
