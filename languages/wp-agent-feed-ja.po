#. Plugin Name of the plugin
#: wp-agent-feed.php
msgid "WP Agent Feed"
msgstr "WP Agent Feed"

#: wp-agent-feed.php
msgid "General Settings"
msgstr "一般設定"

#: wp-agent-feed.php
msgid "Post Types"
msgstr "投稿タイプ"

#: wp-agent-feed.php
msgid "Content-Signal"
msgstr "Content-Signal"

#: wp-agent-feed.php
msgid "Configure how WP Agent Feed serves Markdown responses. Settings defined as constants in wp-config.php take priority over these values."
msgstr "WP Agent Feed の Markdown レスポンス配信方法を設定します。wp-config.php で定義された定数が優先されます。"

#: wp-agent-feed.php
msgid "Defined in wp-config.php. Remove the constant to manage this setting here."
msgstr "wp-config.php で定義されています。この設定をここで管理するには、定数を削除してください。"

#: wp-agent-feed.php
msgid "Cache-Control"
msgstr "Cache-Control"

#: wp-agent-feed.php
msgid "The Content-Signal header value sent with Markdown responses."
msgstr "Markdown レスポンスに付与される Content-Signal ヘッダーの値。"

#: wp-agent-feed.php
msgid "The Cache-Control header value sent with Markdown responses. Leave empty to not send this header."
msgstr "Markdown レスポンスに付与される Cache-Control ヘッダーの値。空にするとヘッダーを送信しません。"

#: wp-agent-feed.php
msgid "Cache Management"
msgstr "キャッシュ管理"

#. translators: %s is the cache directory path
#: wp-agent-feed.php
msgid "Cache directory: %s"
msgstr "キャッシュディレクトリ: %s"

#: wp-agent-feed.php
msgid "Regenerate All Cache"
msgstr "全キャッシュ再生成"

#: wp-agent-feed.php
msgid "Clear All Cache"
msgstr "全キャッシュ削除"

#: wp-agent-feed.php
msgid "Permission denied."
msgstr "権限がありません。"

#. translators: %d is the number of deleted cache files
#: wp-agent-feed.php
msgid "Deleted %d cache files."
msgstr "%d 件のキャッシュファイルを削除しました。"

#: wp-agent-feed.php
msgid "Starting..."
msgstr "開始中…"

#: wp-agent-feed.php
msgid "No posts to process."
msgstr "処理する投稿がありません。"

#: wp-agent-feed.php
msgid "Request failed."
msgstr "リクエストに失敗しました。"

#: wp-agent-feed.php
msgid "processed..."
msgstr "件処理済み…"

#: wp-agent-feed.php
msgid "cache files regenerated."
msgstr "件のキャッシュファイルを再生成しました。"

#: wp-agent-feed.php
msgid "Are you sure you want to clear all cache files?"
msgstr "すべてのキャッシュファイルを削除してもよろしいですか？"

#: wp-agent-feed.php
msgid "Clearing..."
msgstr "削除中…"

#: wp-agent-feed.php
msgid "Settings"
msgstr "設定"

#: wp-agent-feed.php
msgid "Status"
msgstr "ステータス"

#: wp-agent-feed.php
msgid "Writable"
msgstr "書き込み可能"

#: wp-agent-feed.php
msgid "Not writable"
msgstr "書き込み不可"

#: wp-agent-feed.php
msgid "Does not exist"
msgstr "存在しません"

#: wp-agent-feed.php
msgid "Present"
msgstr "あり"

#: wp-agent-feed.php
msgid "Missing"
msgstr "なし"

#: wp-agent-feed.php
msgid "No published posts"
msgstr "公開済み投稿なし"

#. translators: 1: cached count, 2: total count
#: wp-agent-feed.php
msgid "%1$d / %2$d posts cached"
msgstr "%1$d / %2$d 件キャッシュ済み"

#: wp-agent-feed.php
msgid "Cache directory"
msgstr "キャッシュディレクトリ"

#: wp-agent-feed.php
msgid ".htaccess protection"
msgstr ".htaccess 保護"

#: wp-agent-feed.php
msgid "Cache coverage"
msgstr "キャッシュカバー率"

#: wp-agent-feed.php
msgid "Verify Output"
msgstr "出力を検証"

#: wp-agent-feed.php
msgid "Verifying..."
msgstr "検証中…"

#: wp-agent-feed.php
msgid "All checks passed. Markdown output is correct."
msgstr "すべてのチェックに合格しました。Markdown 出力は正常です。"

#: wp-agent-feed.php
msgid "Some checks failed."
msgstr "一部のチェックに失敗しました。"

#: wp-agent-feed.php
msgid "Tested post:"
msgstr "検証した投稿:"

#: wp-agent-feed.php
msgid "No published posts found. Publish at least one post to run the test."
msgstr "公開済みの投稿が見つかりません。検証するには、投稿を1つ以上公開してください。"

#: wp-agent-feed.php
msgid "Cache generation failed. Check that the cache directory is writable."
msgstr "キャッシュの生成に失敗しました。キャッシュディレクトリが書き込み可能か確認してください。"

#: wp-agent-feed.php
msgid "Failed to read the generated cache file."
msgstr "生成されたキャッシュファイルの読み込みに失敗しました。"

#: wp-agent-feed.php
msgid "Check"
msgstr "チェック項目"

#: wp-agent-feed.php
msgid "Expected"
msgstr "期待値"

#: wp-agent-feed.php
msgid "Actual"
msgstr "実際の値"

#: wp-agent-feed.php
msgid "Response Preview"
msgstr "レスポンスプレビュー"

#: wp-agent-feed.php
msgid "succeeded,"
msgstr "件成功、"

#: wp-agent-feed.php
msgid "failed."
msgstr "件失敗。"

#: wp-agent-feed.php
msgid "Check HTTP Headers"
msgstr "HTTP ヘッダーを確認"

#: wp-agent-feed.php
msgid "Checking..."
msgstr "確認中…"

#: wp-agent-feed.php
msgid "Could not connect to the server. This feature may not work in local development environments."
msgstr "サーバーに接続できませんでした。この機能はローカル開発環境では動作しない場合があります。"

#: wp-agent-feed.php
msgid "The server may restrict HEAD requests. If headers appear incorrect, try a GET request with cURL."
msgstr "サーバーが HEAD リクエストを制限している可能性があります。ヘッダーが正しく表示されない場合は、cURL で GET リクエストをお試しください。"

#: wp-agent-feed.php
msgid "Duplicate headers may not be accurately displayed on your WordPress version."
msgstr "お使いの WordPress バージョンでは重複ヘッダーが正確に表示されない場合があります。"
